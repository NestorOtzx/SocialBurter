# ========================================
# DATABASE CONFIGURATION
# ========================================

# Cliente de base de datos a utilizar. Opciones válidas: 'sqlite' o 'postgres'
DB_CLIENT=sqlite

# (Opcional) Ruta del archivo si se usa DB_CLIENT=sqlite
# Por defecto se creará trueque_municipal.db en el directorio superior si no se especifica.
DB_PATH=../trueque_municipal.db

# URL de conexión si se usa DB_CLIENT=postgres (ej. Supabase, Render, Heroku)
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:[PORT]/[DATABASE]?sslmode=require

# ========================================
# SERVER CONFIGURATION
# ========================================
PORT=3000
JWT_SECRET=super_secret_jwt_key_12345
